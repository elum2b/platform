    REFERENCE_CACHE_SIZE=0 \
    REFERENCE_CACHE_TTL_CHECK=0s

# Tasks service PostgreSQL, cache, partner lease and Lua runtime settings.
# TASKS_* overrides global POSTGRES_* and SERVICES_* settings.
ENV TASKS_POSTGRES_HOST= \
    TASKS_POSTGRES_PORT=0 \
    TASKS_POSTGRES_USER= \
    TASKS_POSTGRES_PASSWORD= \
    TASKS_POSTGRES_DATABASE= \
    TASKS_MAX_CONNECTIONS=0 \
    TASKS_QUERY_TIMEOUT=0s \
    TASKS_CACHE_L1_DELAY=0s \
    TASKS_CACHE_L2_DELAY=0s \
    TASKS_CACHE_ENABLED=false \
    TASKS_CACHE_SIZE=0 \
    TASKS_CACHE_TTL_CHECK=0s \
    TASKS_PARTNER_START_LEASE_DURATION=0s \
    TASKS_RUNTIME_ENABLED=false \
    TASKS_RUNTIME_SCRIPT_CACHE_TTL=0s \
    TASKS_RUNTIME_TIMEOUT=0s \
    TASKS_RUNTIME_MAX_MEMORY=0 \
    TASKS_RUNTIME_MAX_HTTP_REQUESTS=0 \
    TASKS_RUNTIME_MAX_RESPONSE_BYTES=0 \
    TASKS_RUNTIME_JSON_BOUNDARY=false \
    TASKS_RUNTIME_STATE_POOL_SIZE=0

COPY --from=build /platform /platform

USER nonroot:nonroot

ENTRYPOINT ["/platform"]
